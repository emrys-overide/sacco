# Copy to functions/.env only after choosing the target Firebase project.
# These values are configuration, not credentials. Never place passwords,
# database URLs, webhook tokens, private keys, or API secrets in this file.

# Replace PROJECT_ID with the project selected by `firebase use`.
APP_URL=https://PROJECT_ID.web.app
TRUST_PROXY=true
DATABASE_SSL=true
PASSWORD_AUTH_ENABLED=true
JWT_EXPIRES_SECONDS=28800
OFFICER_TOTP_REQUIRED=false
TOTP_ISSUER=Matatu SACCO

# Firebase Functions already provides project identity through Application
# Default Credentials. Do not add a service-account JSON key.

# Keep the bank callback disabled until the bank onboarding values are confirmed
# and the endpoint has passed the observe-only test checklist.
COOP_IPN_ENABLED=false
COOP_IPN_AUTH_MODE=TOKEN
COOP_IPN_TOKEN_HEADER=authorization
COOP_IPN_TOKEN_SCHEME=Bearer
COOP_IPN_SUCCESS_MESSAGE_CODE=2XX
COOP_OBSERVE_ONLY=true
COOP_AUTO_POSTING_ENABLED=false

ALLOW_DEV_AUTH_FALLBACK=false
ALLOW_DEV_JWT_AUTH=false
ALLOW_IN_MEMORY_DB=false

# Set sensitive runtime values manually in the structured Secret Manager secret
# SACCO_RUNTIME_SECRETS. See docs/firebase-deployment.md for its allowed keys.
