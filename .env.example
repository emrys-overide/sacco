# Copy this file to .env for local development.
# Keep .env files out of git. Put real production values in your host/CI secret store.

PORT=3000
APP_URL="https://your-public-app-url.example"

# Primary application database. Apply migrations 001 through 004 before startup.
DATABASE_URL="postgresql://sacco_app:change-me@localhost:5432/sacco_prod"
DATABASE_SSL=false
POSTGRES_IMAGE="postgres:18-alpine"

# Password/TOTP authentication is the normal SACCO sign-in path.
PASSWORD_AUTH_ENABLED=true
# A long random HMAC signing secret for SACCO browser sessions.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-bytes"
JWT_EXPIRES_SECONDS=28800
# Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"
TOTP_ISSUER="Matatu SACCO"

# Local development persistence option. Keep false in production.
ALLOW_DEV_AUTH_FALLBACK=false
ALLOW_DEV_JWT_AUTH=false
ALLOW_IN_MEMORY_DB=false

# Member activation and password reset. Configure a trusted HTTPS SMS/OTP
# service; the server sends { to, code, expiresInSeconds, purpose } and never
# returns or logs the code. Use a random value of at least 32 characters.
MEMBER_OTP_PEPPER="replace-with-a-long-random-secret-at-least-32-bytes"
MEMBER_OTP_DELIVERY_WEBHOOK_URL="https://your-trusted-otp-delivery-service.example/send"
# MEMBER_OTP_DELIVERY_AUTHORIZATION="Bearer provider-secret"

# Co-operative Bank B2B/IPN event notification. The bank posts to
# APP_URL/api/webhooks/coop-bank/b2b-ipn after your B2B onboarding is approved.
# Use token authentication unless the bank requires Basic authentication.
COOP_B2B_IPN_AUTH_MODE="token"
COOP_B2B_IPN_TOKEN="replace-with-a-long-random-bank-webhook-token"
# COOP_B2B_IPN_BASIC_USERNAME="bank-issued-or-agreed-username"
# COOP_B2B_IPN_BASIC_PASSWORD="bank-issued-or-agreed-password"
# Comma-separated, full Co-op account numbers authorised to post events.
# Set this before enabling the endpoint; no incoming event is accepted while empty.
COOP_B2B_ALLOWED_ACCOUNT_NUMBERS=""
COOP_B2B_IPN_CURRENCY="KES"

# Optional Firestore development adapter. PostgreSQL is the production path.
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/firestore-service-account.json"
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
FIRESTORE_DATABASE_ID="your-firestore-database-id"

# Optional AI integration
GEMINI_API_KEY="your-gemini-api-key"
