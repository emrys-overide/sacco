# Copy this file to .env for local development.
# Keep .env files out of git. Put real production values in your host/CI secret store.

PORT=3000
APP_URL="https://your-public-app-url.example"
# Set true only when the app is behind one trusted reverse proxy that supplies
# X-Forwarded-Proto. Direct production TLS should leave this false.
TRUST_PROXY=false

# Primary application database. Apply every pending migration before startup.
DATABASE_URL="postgresql://sacco_app:change-me@localhost:5432/sacco_prod"
# Supabase: use the Session pooler URL on port 5432 for this persistent Node
# service. Keep TLS enabled. For the strongest verification, append
# ?sslmode=verify-full and install the project CA certificate on the host.
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_MS=10000
BACKGROUND_PROCESSOR_ENABLED=false
# Required only with ?sslmode=verify-full.
# DATABASE_CA_CERT_PATH="/absolute/path/to/supabase-ca.crt"
POSTGRES_IMAGE="postgres:18-alpine"

# Members and officers use one server-backed phone/email + password flow.
PASSWORD_AUTH_ENABLED=true
# A long random HMAC signing secret for SACCO browser sessions.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-bytes"
JWT_EXPIRES_SECONDS=28800
# Optional stronger officer login. Keep false for the simple default flow.
OFFICER_TOTP_REQUIRED=false
# Required only when OFFICER_TOTP_REQUIRED=true. Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"
TOTP_ISSUER="Matatu SACCO"

# Local development persistence option. Keep false in production.
ALLOW_DEV_AUTH_FALLBACK=false
ALLOW_DEV_JWT_AUTH=false
ALLOW_IN_MEMORY_DB=false


# Co-operative Bank posts to APP_URL/api/integrations/coop/ipn. Safe defaults
# are disabled, observe-only, and never auto-posting.
COOP_IPN_ENABLED=false
COOP_IPN_AUTH_MODE="TOKEN"
COOP_IPN_TOKEN="replace-with-a-long-random-bank-webhook-token"
# The supplied bank document says token authentication but does not define the
# header or scheme. Confirm these during onboarding; defaults are conventional.
COOP_IPN_TOKEN_HEADER="authorization"
COOP_IPN_TOKEN_SCHEME="Bearer"
# COOP_IPN_BASIC_USERNAME="bank-issued-or-agreed-username"
# COOP_IPN_BASIC_PASSWORD="bank-issued-or-agreed-password"
COOP_ALLOWED_ACCOUNT_NUMBERS=""
COOP_IPN_SUCCESS_MESSAGE_CODE="2XX"
COOP_OBSERVE_ONLY=true
COOP_AUTO_POSTING_ENABLED=false

# Optional AI integration
GEMINI_API_KEY="your-gemini-api-key"
