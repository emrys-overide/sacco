# Copy this file to .env for local development.
# Keep .env files out of git. Put real production values in your host/CI secret store.

PORT=3000
APP_URL="https://your-public-app-url.example"

# Primary application database. Apply migrations 001 through 004 before startup.
DATABASE_URL="postgresql://sacco_app:change-me@localhost:5432/sacco_prod"
DATABASE_SSL=false
POSTGRES_IMAGE="postgres:18-alpine"

# Firebase Auth: server-side token verification
FIREBASE_PROJECT_ID="your-firebase-project-id"
# Choose one server credential strategy:
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/firebase-admin-service-account.json"
# FIREBASE_SERVICE_ACCOUNT_JSON="{\"type\":\"service_account\",\"project_id\":\"...\"}"

# Local development fallback only. Keep false in production.
ALLOW_DEV_AUTH_FALLBACK=false
ALLOW_DEV_JWT_AUTH=false
ALLOW_IN_MEMORY_DB=false

# Legacy dev JWT fallback. Not used for production Firebase Auth.
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-bytes"
JWT_EXPIRES_SECONDS=28800

# Safaricom Daraja C2B integration
DARAJA_MODE="sandbox"
DARAJA_CONSUMER_KEY="your-daraja-consumer-key"
DARAJA_CONSUMER_SECRET="your-daraja-consumer-secret"
DARAJA_SHORTCODE="600000"
DARAJA_CALLBACK_BASE_URL="https://your-public-app-url.example"
DARAJA_STK_PUSH_ENABLED=false

# Optional Firestore development adapter. PostgreSQL is the production path.
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
FIRESTORE_DATABASE_ID="your-firestore-database-id"

# Optional Firebase client config for browser-side Firebase features
VITE_FIREBASE_AUTH_ENABLED=true
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
VITE_FIREBASE_API_KEY="your-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-firebase-project.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="your-firebase-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"

# Optional AI integration
GEMINI_API_KEY="your-gemini-api-key"
