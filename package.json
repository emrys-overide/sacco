{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx start.ts",
    "build:client": "vite build",
    "build:client:static-preview": "VITE_STATIC_HOSTING_PREVIEW=true vite build",
    "build:server": "esbuild start.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:functions": "npm --prefix functions run build",
    "build": "npm run build:client && npm run build:server",
    "firebase:prepare": "npm run build && npm run build:functions",
    "firebase:prepare:static-preview": "npm run build:client:static-preview",
    "firebase:emulators": "DEBUG= npx firebase-tools@15.24.0 emulators:start --only hosting,functions,firestore",
    "test:firestore-rules": "DEBUG= npx firebase-tools@15.24.0 emulators:exec --only firestore --project demo-matatu-sacco \"node scripts/check-firestore-deny.mjs\"",
    "test:static-hosting-preview": "DEBUG= npx firebase-tools@15.24.0 --config firebase.static-preview.json emulators:exec --only hosting --project demo-matatu-sacco \"node scripts/check-static-hosting-preview.mjs\"",
    "start": "node dist/server.cjs",
    "db:up": "node scripts/database.mjs up",
    "db:migrate": "node scripts/database.mjs migrate",
    "db:status": "node scripts/database.mjs status",
    "db:down": "node scripts/database.mjs down",
    "simulate:coop-ipn": "node scripts/simulate-coop-ipn.mjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
