rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Officials and members use the HTTPS API, where the SACCO role and the
    // trusted linkedMemberId are checked on every request. The browser does not
    // read Firestore directly, so Firebase Auth claims alone cannot accidentally
    // expose ledger or member records. Admin SDK access is controlled by IAM and
    // intentionally bypasses these client rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
